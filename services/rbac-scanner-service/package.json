{
  "name": "rbac-scanner-service",
  "version": "0.1.0",
  "private": true,
  "description": "gRPC service: parses RBAC snapshots, runs the findings engine, owns the scans table",
  "main": "dist/server.js",
  "scripts": {
    "gen:proto": "bash scripts/gen-proto.sh",
    "build": "npm run gen:proto && tsc -p tsconfig.json",
    "dev": "npm run gen:proto && ts-node src/server.ts",
    "start": "node dist/server.js",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@aws-sdk/client-sqs": "^3.1079.0",
    "@grpc/grpc-js": "^1.14.4",
    "@opentelemetry/auto-instrumentations-node": "^0.55.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.57.0",
    "@opentelemetry/sdk-node": "^0.57.0",
    "grpc-health-check": "^2.1.0",
    "jszip": "^3.10.1",
    "long": "^5.2.4",
    "pg": "^8.13.1",
    "protobufjs": "^7.4.0"
  },
  "devDependencies": {
    "@types/node": "^22",
    "@types/pg": "^8.11.10",
    "ts-node": "^10.9.2",
    "ts-proto": "^2.11.8",
    "typescript": "^5"
  }
}
