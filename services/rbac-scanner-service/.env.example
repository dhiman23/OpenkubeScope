PORT=50051

# RDS Postgres connection string. Same instance as core-api/report-service,
# this service only ever touches the `scanner` schema (see migrations/).
DATABASE_URL=postgres://user:password@your-rds-endpoint.region.rds.amazonaws.com:5432/kubescope
# Set to "false" for local/dev Postgres without TLS. Defaults to RDS-style TLS.
DATABASE_SSL=true
DATABASE_POOL_MAX=10

# OpenTelemetry (optional). If OTEL_EXPORTER_OTLP_ENDPOINT is unset, tracing is off.
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_SERVICE_NAME=rbac-scanner-service

# Event-driven scan flow: this service consumes rbac_scan_queue; KEDA scales on
# queue depth. Optional — if unset, the SQS consumer is disabled and scans run
# only via the synchronous ScanSnapshot RPC (local dev needs no AWS).
# Credentials via the default provider chain (IRSA in-cluster).
SCAN_SQS_QUEUE_URL=
AWS_REGION=
