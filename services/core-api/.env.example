PORT=8080

# RDS Postgres. Same instance as the other services; core-api owns the `core` schema.
DATABASE_URL=postgres://user:password@your-rds-endpoint.region.rds.amazonaws.com:5432/kubescope
DATABASE_SSL=true
DATABASE_POOL_MAX=10

# Auth — HMAC secret for signing/verifying JWTs issued by core-api.
AUTH_JWT_SECRET=change-me-to-a-long-random-string
AUTH_JWT_EXPIRES_IN=7d

# gRPC addresses of the internal services.
SCANNER_SERVICE_ADDR=localhost:50051
REPORT_SERVICE_ADDR=localhost:50052

# Cron auth — bearer token gating POST /cron/scheduled-reports.
CRON_SECRET=change-me

# Frontend origin(s) for CORS + redirect base, comma-separated.
PUBLIC_SITE_URL=http://localhost:3000
CORS_ORIGINS=http://localhost:3000

# OpenTelemetry (optional). If OTEL_EXPORTER_OTLP_ENDPOINT is unset, tracing is off.
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_SERVICE_NAME=core-api
