{
  "name": "core-api",
  "version": "0.1.0",
  "private": true,
  "description": "BFF / REST API: auth, workspaces, clusters, scan/report orchestration. Calls rbac-scanner-service and report-service over gRPC.",
  "main": "dist/server.js",
  "scripts": {
    "gen:proto": "bash scripts/gen-proto.sh",
    "build": "npm run gen:proto && tsc -p tsconfig.json",
    "dev": "npm run gen:proto && ts-node src/server.ts",
    "start": "node dist/server.js",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@aws-sdk/client-sqs": "^3.1079.0",
    "@grpc/grpc-js": "^1.14.4",
    "@opentelemetry/auto-instrumentations-node": "^0.78.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.220.0",
    "@opentelemetry/sdk-node": "^0.220.0",
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.5",
    "express": "^5.2.1",
    "jsonwebtoken": "^9.0.3",
    "long": "^5.2.4",
    "multer": "^2.2.0",
    "pg": "^8.13.1",
    "@bufbuild/protobuf": "^2.12.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/multer": "^2.2.0",
    "@types/node": "^22",
    "@types/pg": "^8.11.10",
    "ts-node": "^10.9.2",
    "ts-proto": "^2.11.8",
    "typescript": "^5"
  }
}
