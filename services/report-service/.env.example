PORT=50052

# RDS Postgres. Same instance as core-api/rbac-scanner-service, this service
# only touches the `report` schema (see migrations/).
DATABASE_URL=postgres://user:password@your-rds-endpoint.region.rds.amazonaws.com:5432/kubescope
DATABASE_SSL=true
DATABASE_POOL_MAX=10

# gRPC address of rbac-scanner-service (for fetching scan data).
SCANNER_SERVICE_ADDR=localhost:50051

# Redis for caching scan-data fetches from the scanner (locked decision:
# "Redis for caching scan results between scanner and report service").
# Optional — if unset, caching is disabled and every report re-fetches.
REDIS_URL=redis://localhost:6379
SCAN_CACHE_TTL_SECONDS=300

# Used in Slack notification deep-links back to the app.
PUBLIC_SITE_URL=https://kubescope.dev

# OpenTelemetry (optional). If OTEL_EXPORTER_OTLP_ENDPOINT is unset, tracing is off.
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_SERVICE_NAME=report-service
