{
  "name": "report-service",
  "version": "0.1.0",
  "private": true,
  "description": "gRPC service: builds RBAC audit reports (JSON/CSV/PDF), owns the reports + scheduled_reports tables, calls rbac-scanner-service for scan data",
  "main": "dist/server.js",
  "scripts": {
    "gen:proto": "bash scripts/gen-proto.sh",
    "build": "npm run gen:proto && tsc -p tsconfig.json",
    "dev": "npm run gen:proto && ts-node src/server.ts",
    "start": "node dist/server.js",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@grpc/grpc-js": "^1.14.4",
    "@opentelemetry/auto-instrumentations-node": "^0.78.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.220.0",
    "@opentelemetry/sdk-node": "^0.220.0",
    "grpc-health-check": "^2.1.0",
    "ioredis": "^5.4.2",
    "jspdf": "^4.2.0",
    "jspdf-autotable": "^5.0.7",
    "long": "^5.2.4",
    "pg": "^8.13.1",
    "@bufbuild/protobuf": "^2.12.0"
  },
  "devDependencies": {
    "@types/node": "^22",
    "@types/pg": "^8.11.10",
    "ts-node": "^10.9.2",
    "ts-proto": "^2.11.8",
    "typescript": "^5"
  }
}
